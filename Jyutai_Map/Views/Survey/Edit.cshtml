@model Jyutai_Map.Models.TrafficSurvey

@{
    ViewData["Title"] = "アンケート編集";
}

<h1>アンケート編集</h1>

<h4>投稿内容の修正</h4>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedAt" />
            <div class="form-group mb-3">
                <label asp-for="Rating" class="control-label"></label>
                <div>
                    @for (int i = 1; i <= 5; i++)
                    {
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" asp-for="Rating" value="@i" id="rating@i" required>
                            <label class="form-check-label" for="rating@i">@i</label>
                        </div>
                    }
                </div>
                <span asp-validation-for="Rating" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Comment" class="control-label"></label>
                <textarea asp-for="Comment" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Comment" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <input type="submit" value="保存" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">一覧に戻る</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
