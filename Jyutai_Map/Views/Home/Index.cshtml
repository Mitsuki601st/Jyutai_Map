@model IEnumerable<Jyutai_Map.Models.TrafficReport>
@{
    ViewData["Title"] = "渋滞状況一覧";
}

<div class="text-center">
    <h1 class="display-4">現在の渋滞状況</h1>
    <p>リアルタイムの交通レポートを表示しています。</p>
    <p>
        <a asp-action="Create" class="btn btn-primary">新規報告を作成</a>
    </p>
</div>

<div class="container mt-4">
    <table class="table table-striped table-bordered">
        <thead class="thead-dark">
            <tr>
                <th>場所</th>
                <th>混雑レベル (1-5)</th>
                <th>詳細説明</th>
                <th>報告日時</th>
                <th>操作</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var report in Model)
                {
                    <tr>
                        <td>@report.Location</td>
                        <td>
                            <span class="badge @(report.CongestionLevel >= 4 ? "bg-danger" : report.CongestionLevel >= 3 ? "bg-warning text-dark" : "bg-success")">
                                @report.CongestionLevel
                            </span>
                        </td>
                        <td>@report.Description</td>
                        <td>@report.ReportedAt.ToLocalTime().ToString("yyyy/MM/dd HH:mm")</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@report.Id" class="btn btn-sm btn-outline-primary">編集</a>
                            <a asp-action="Delete" asp-route-id="@report.Id" class="btn btn-sm btn-outline-danger">削除</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="5" class="text-center">レポートがありません。</td>
                </tr>
            }
        </tbody>
    </table>

    <div id="map" style="width: 100%; height: 600px; margin-top: 20px;"></div>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

    <script>
        // ③ 地図の初期化（[緯度, 経度], ズームレベル）※例として東京駅付近
        const map = L.map('map').setView([26.2064, 127.6465], 13);

        // ④ OpenStreetMap のタイルレイヤー（API）を追加
        L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19,
            attribution: '&copy; <a href="http://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
        }).addTo(map);

        // ⑤ オプション: マーカーを配置する
            const marker = L.marker([26.2064, 127.6465]).addTo(map);
        marker.bindPopup("<b>はいさい！</b><br>ここが那覇空港です。").openPopup();
    </script>
    }
</div>
